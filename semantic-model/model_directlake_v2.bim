            "sourceProviderType": "varchar",
            "annotations": [
              {
                "name": "Description",
                "value": "シフト"
              }
            ]
          },
          {
            "name": "PlannedQuantity",
            "dataType": "int64",
            "sourceColumn": "PlannedQuantity",
            "sourceProviderType": "bigInt",
            "annotations": [
              {
                "name": "Description",
                "value": "計画数量"
              }
            ]
          },
          {
            "name": "ActualQuantity",
            "dataType": "int64",
            "sourceColumn": "ActualQuantity",
            "sourceProviderType": "bigInt",
            "annotations": [
              {
                "name": "Description",
                "value": "実績数量"
              }
            ]
          },
          {
            "name": "DefectQuantity",
            "dataType": "int64",
            "sourceColumn": "DefectQuantity",
            "sourceProviderType": "bigInt",
            "annotations": [
              {
                "name": "Description",
                "value": "不良数量"
              }
            ]
          },
          {
            "name": "YieldRate",
            "dataType": "double",
            "sourceColumn": "YieldRate",
            "sourceProviderType": "real",
            "formatString": "0.0%",
            "annotations": [
              {
                "name": "Description",
                "value": "歩留まり率"
              }
            ]
          },
          {
            "name": "WorkHours",
            "dataType": "double",
            "sourceColumn": "WorkHours",
            "sourceProviderType": "real",
            "annotations": [
              {
                "name": "Description",
                "value": "作業時間"
              }
            ]
          },
          {
            "name": "DowntimeMinutes",
            "dataType": "int64",
            "sourceColumn": "DowntimeMinutes",
            "sourceProviderType": "bigInt",
            "annotations": [
              {
                "name": "Description",
                "value": "設備停止時間"
              }
            ]
          }
        ],
        "measures": [
          {
            "name": "平均歩留まり率",
            "expression": "AVERAGE(FactProduction[YieldRate])",
            "formatString": "0.0%"
          },
          {
            "name": "生産計画数量合計",
            "expression": "SUM(FactProduction[PlannedQuantity])",
            "formatString": "#,##0"
          },
          {
            "name": "生産実績数量合計",
            "expression": "SUM(FactProduction[ActualQuantity])",
            "formatString": "#,##0"
          },
          {
            "name": "不良数量合計",
            "expression": "SUM(FactProduction[DefectQuantity])",
            "formatString": "#,##0"
          },
          {
            "name": "計画達成率",
            "expression": "DIVIDE(SUM(FactProduction[ActualQuantity]), SUM(FactProduction[PlannedQuantity]))",
            "formatString": "0.0%"
          },
          {
            "name": "歩留まり異常件数",
            "expression": "CALCULATE(COUNTROWS(FactProduction), FactProduction[YieldRate] < 0.90)",
            "formatString": "#,##0"
          },
          {
            "name": "設備稼働率",
            "expression": "DIVIDE(SUM(FactProduction[WorkHours]) * 60 - SUM(FactProduction[DowntimeMinutes]), SUM(FactProduction[WorkHours]) * 60)",
            "formatString": "0.0%"
          },
          {
            "name": "平均ダウンタイム",
            "expression": "AVERAGE(FactProduction[DowntimeMinutes])",
            "formatString": "#,##0"
          },
          {
            "name": "生産記録数",
            "expression": "COUNTROWS(FactProduction)",
            "formatString": "#,##0"
          }
        ],
        "partitions": [
          {
            "name": "FactProduction_part",
            "mode": "directLake",
            "source": {
              "type": "entity",
              "entityName": "FactProduction",
              "schemaName": "dbo",
              "expressionSource": "DatabaseQuery"
            }
          }
        ]
      },
      {
