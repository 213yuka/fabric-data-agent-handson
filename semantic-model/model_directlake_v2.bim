            "expression": "SUM(FactQualityInspection[DefectCount])",
            "formatString": "#,##0"
          },
          {
            "name": "不良率",
            "expression": "DIVIDE(SUM(FactQualityInspection[DefectCount]), SUM(FactQualityInspection[SampleSize]))",
            "formatString": "0.0%"
