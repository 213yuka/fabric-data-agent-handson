          {
            "name": "StockStatus",
            "dataType": "string",
            "sourceColumn": "StockStatus",
            "sourceProviderType": "varchar",
            "annotations": [
              {
                "name": "Description",
                "value": "在庫ステータス"
              }
            ]
          },
          {
            "name": "LastReceiptDateKey",
            "dataType": "int64",
            "sourceColumn": "LastReceiptDateKey",
            "sourceProviderType": "bigInt",
            "isHidden": true
          },
          {
            "name": "ShelfLocation",
            "dataType": "string",
            "sourceColumn": "ShelfLocation",
            "sourceProviderType": "varchar",
            "annotations": [
              {
                "name": "Description",
                "value": "棚番"
              }
            ]
          }
        ],
        "measures": [
          {
            "name": "在庫総数",
            "expression": "SUM(FactInventorySnapshot[CurrentStock])",
            "formatString": "#,##0"
          },
          {
            "name": "在庫不足SKU数",
            "expression": "CALCULATE(COUNTROWS(FactInventorySnapshot), FactInventorySnapshot[StockStatus] = \"在庫不足\")",
            "formatString": "#,##0"
          },
          {
            "name": "過剰在庫SKU数",
            "expression": "CALCULATE(COUNTROWS(FactInventorySnapshot), FactInventorySnapshot[StockStatus] = \"過剰在庫\")",
            "formatString": "#,##0"
          },
          {
            "name": "在庫充足率",
            "expression": "DIVIDE(CALCULATE(COUNTROWS(FactInventorySnapshot), FactInventorySnapshot[CurrentStock] >= FactInventorySnapshot[SafetyStock]), COUNTROWS(FactInventorySnapshot))",
            "formatString": "0.0%"
          }
        ],
