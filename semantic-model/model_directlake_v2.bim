            "name": "合格率",
            "expression": "DIVIDE(CALCULATE(COUNTROWS(FactQualityInspection), FactQualityInspection[Result] = \"合格\"), COUNTROWS(FactQualityInspection))",
            "formatString": "0.0%"
          },
          {
            "name": "不合格率",
            "expression": "DIVIDE(CALCULATE(COUNTROWS(FactQualityInspection), FactQualityInspection[Result] = \"不合格\"), COUNTROWS(FactQualityInspection))",
            "formatString": "0.0%"
          },
