      {
        "name": "FactSales",
        "columns": [
          {
            "name": "SalesKey",
            "dataType": "int64",
            "sourceColumn": "SalesKey",
            "sourceProviderType": "bigInt",
            "isHidden": true
          },
          {
            "name": "OrderID",
            "dataType": "string",
            "sourceColumn": "OrderID",
            "sourceProviderType": "varchar",
            "annotations": [
              {
                "name": "Description",
                "value": "受注ID"
              }
            ]
          },
          {
            "name": "OrderDateKey",
            "dataType": "int64",
            "sourceColumn": "OrderDateKey",
            "sourceProviderType": "bigInt",
            "isHidden": true
          },
          {
            "name": "ShipDateKey",
            "dataType": "int64",
            "sourceColumn": "ShipDateKey",
            "sourceProviderType": "bigInt",
            "isHidden": true
          },
          {
            "name": "CustomerKey",
            "dataType": "int64",
            "sourceColumn": "CustomerKey",
            "sourceProviderType": "bigInt",
            "isHidden": true
          },
          {
            "name": "ProductKey",
            "dataType": "int64",
            "sourceColumn": "ProductKey",
            "sourceProviderType": "bigInt",
            "isHidden": true
          },
          {
            "name": "Quantity",
            "dataType": "int64",
            "sourceColumn": "Quantity",
            "sourceProviderType": "bigInt",
            "annotations": [
              {
                "name": "Description",
                "value": "受注数量"
              }
            ]
          },
          {
            "name": "UnitSellingPrice",
            "dataType": "int64",
            "sourceColumn": "UnitSellingPrice",
            "sourceProviderType": "bigInt",
            "formatString": "¥#,##0",
            "annotations": [
              {
                "name": "Description",
                "value": "販売単価"
              }
            ]
          },
          {
            "name": "TotalAmount",
            "dataType": "int64",
            "sourceColumn": "TotalAmount",
            "sourceProviderType": "bigInt",
            "formatString": "¥#,##0",
            "annotations": [
              {
                "name": "Description",
                "value": "合計金額"
              }
            ]
          },
          {
            "name": "DiscountRate",
            "dataType": "double",
            "sourceColumn": "DiscountRate",
            "sourceProviderType": "real",
            "formatString": "0%",
            "annotations": [
              {
                "name": "Description",
                "value": "割引率"
              }
            ]
          },
          {
            "name": "Status",
            "dataType": "string",
            "sourceColumn": "Status",
            "sourceProviderType": "varchar",
            "annotations": [
              {
                "name": "Description",
                "value": "受注ステータス"
              }
            ]
          },
          {
            "name": "DeliveryRegion",
            "dataType": "string",
            "sourceColumn": "DeliveryRegion",
            "sourceProviderType": "varchar",
            "annotations": [
              {
                "name": "Description",
                "value": "納品先地域"
              }
            ]
          }
        ],
        "measures": [
          {
            "name": "売上合計",
            "expression": "SUM(FactSales[TotalAmount])",
            "formatString": "¥#,##0"
          },
          {
            "name": "有効売上合計",
            "expression": "CALCULATE(SUM(FactSales[TotalAmount]), FactSales[Status] <> \"キャンセル\")",
            "formatString": "¥#,##0"
          },
          {
            "name": "受注件数",
            "expression": "COUNTROWS(FactSales)",
            "formatString": "#,##0"
          },
          {
            "name": "有効受注件数",
            "expression": "CALCULATE(COUNTROWS(FactSales), FactSales[Status] <> \"キャンセル\")",
            "formatString": "#,##0"
          },
          {
            "name": "受注数量合計",
            "expression": "SUM(FactSales[Quantity])",
            "formatString": "#,##0"
          },
          {
            "name": "平均受注単価",
            "expression": "AVERAGE(FactSales[UnitSellingPrice])",
            "formatString": "¥#,##0"
          },
          {
            "name": "平均受注金額",
            "expression": "DIVIDE(SUM(FactSales[TotalAmount]), COUNTROWS(FactSales))",
            "formatString": "¥#,##0"
          },
          {
            "name": "キャンセル率",
            "expression": "DIVIDE(CALCULATE(COUNTROWS(FactSales), FactSales[Status] = \"キャンセル\"), COUNTROWS(FactSales))",
            "formatString": "0.0%"
          },
          {
            "name": "出荷済件数",
            "expression": "CALCULATE(COUNTROWS(FactSales), FactSales[Status] = \"出荷済\")",
            "formatString": "#,##0"
          },
          {
            "name": "粗利額",
            "expression": "SUMX(FactSales, FactSales[TotalAmount] - (RELATED(DimProduct[UnitCost]) * FactSales[Quantity]))",
            "formatString": "¥#,##0"
          },
          {
            "name": "粗利率",
            "expression": "DIVIDE([粗利額], [売上合計])",
            "formatString": "0.0%"
          },
          {
            "name": "顧客数",
            "expression": "DISTINCTCOUNT(FactSales[CustomerKey])",
            "formatString": "#,##0"
          },
          {
            "name": "売上累計YTD",
            "expression": "TOTALYTD([有効売上合計], DimDate[FullDate], \"3/31\")",
            "formatString": "¥#,##0"
          }
        ],
        "partitions": [
          {
            "name": "FactSales_part",
            "mode": "directLake",
            "source": {
              "type": "entity",
              "entityName": "FactSales",
              "schemaName": "dbo",
              "expressionSource": "DatabaseQuery"
            }
          }
        ]
      },
